    int32:current_depth;
};

pub func:parse_rule_1 = CompactHandle<GreenNode>(wild ParserCtx->:pctx) {
    drop puts("ENTER rule 1");
    if (pctx->current_depth >= 4096i32) {
        CompactHandle<GreenNode>:empty_h;
        empty_h.index = 0u32;
        empty_h.generation = 0u32;
        drop puts("FAIL DEPTH rule 1");
        pass(empty_h);
    }
    pctx->current_depth = pctx->current_depth + 1i32;
    int64:start_cursor = pctx->lexer->cursor;
    CompactHandle<GreenNode>:empty_h;
    empty_h.index = 0u32;
    empty_h.generation = 0u32;
    CompactHandle<GreenNode>:h0 = raw parse_rule_15(pctx);
    if (h0.index != 0u32 || h0.generation != 0u32) {
        pctx->current_depth = pctx->current_depth - 1i32;
        drop puts("SUCC choice rule 1");
        pass(h0);
    }
    pctx->lexer->cursor = start_cursor;
    CompactHandle<GreenNode>:h1 = raw parse_rule_17(pctx);
    if (h1.index != 0u32 || h1.generation != 0u32) {
        pctx->current_depth = pctx->current_depth - 1i32;
        drop puts("SUCC choice rule 1");
        pass(h1);
    }
    pctx->lexer->cursor = start_cursor;
    pctx->current_depth = pctx->current_depth - 1i32;
    drop puts("FAIL choice rule 1");
    pass(empty_h);
};

