pub func:main = int32() {
    int64:x = 100i64;
    int64:y = 200i64;
    int64:pack = (x << 32i64) | y;
    int64:rx = (pack >> 32i64) & 0xFFFFFFFFi64;
    int64:ry = pack & 0xFFFFFFFFi64;
    if (rx != 100i64) { exit(1i32); }
    if (ry != 200i64) { exit(2i32); }
    exit(0i32);
};

func:failsafe = int32(tbb32:err_code) {
    exit(err_code => int32);
};
