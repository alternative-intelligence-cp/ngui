pub struct:Test = {
    int64->:ptr;
};

pub func:main = int32() {
    int64->:p = alloc(8i64 * 3i64) => int64->;
    p[0] = 0i64;
    
    wild Test->:t = alloc(@sizeof(Test)) => Test->;
    t->ptr = p;
    
    int64->:local_ptr = t->ptr;
    local_ptr[0] = 42i64;
    
    int32:res = 0i32;
    if (t->ptr[0] != 42i64) {
        res = 1i32;
    }
    
    free(p);
    free(t);
    exit(res);
};

func:failsafe = int32(tbb32:err_code) {
    exit(err_code => int32);
};
