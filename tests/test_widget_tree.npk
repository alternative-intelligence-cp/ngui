use "handle.npk".*;
use "../src/core/widget.npk".*;
use "/home/randy/Workspace/REPOS/nitpick-packages/packages/nitpick-list/src/doubly.npk".*;

pub func:main = int32() {
    // 1. Create the arena
    int64:arena = npk_handle_arena_create();
    
    // 2. Create parent widget
    int64:hw = npk_handle_alloc(arena, 256i64);
    Widget->:parent_widget = cast_unchecked<Widget->>(npk_handle_deref(hw));
    raw widget_init(parent_widget);
    Handle<Widget>:parent_handle = cast_unchecked<Handle<Widget> >(hw);
    
    // 3. Create child widgets
    int64:hw1 = npk_handle_alloc(arena, 256i64);
    Widget->:child1 = cast_unchecked<Widget->>(npk_handle_deref(hw1));
    raw widget_init(child1);
    Handle<Widget>:h1 = cast_unchecked<Handle<Widget> >(hw1);
    
    int64:hw2 = npk_handle_alloc(arena, 256i64);
    Widget->:child2 = cast_unchecked<Widget->>(npk_handle_deref(hw2));
    raw widget_init(child2);
    Handle<Widget>:h2 = cast_unchecked<Handle<Widget> >(hw2);
    
    // 4. Add children to parent
    raw widget_add_child(parent_widget, h1);
    
    raw widget_add_child(parent_widget, h2);
    
    // 5. Verify children list size
    int64:len = parent_widget->children->count;
    if (len != 2i64) { exit(30i32); }
    
    // 6. Remove first child
    raw widget_remove_child(parent_widget, h1);
    
    int64:len2 = parent_widget->children->count;
    if (len2 != 1i64) { exit(50i32); }
    
    // 7. Verify the remaining child is h2
    Handle<Widget>:peek_handle = cast_unchecked<Handle<Widget> >(parent_widget->children->items[0i64]);
    if (cast_unchecked<int64>(peek_handle) != cast_unchecked<int64>(h2)) { exit(60i32); }
    
    // 8. Cleanup
    raw widget_destroy(child1);
    raw widget_destroy(child2);
    raw widget_destroy(parent_widget);
    
    drop npk_handle_arena_destroy(arena);
    
    exit(0i32);
};

func:failsafe = int32(tbb32:err_code) {
    exit(err_code => int32);
};
